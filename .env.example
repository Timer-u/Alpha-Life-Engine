# Alpha-Life Engine Environment Configuration

# 开发环境配置
VITE_API_BASE_URL=http://localhost:8787/api
VITE_ENVIRONMENT=development
VITE_LOG_LEVEL=debug

# 应用配置
VITE_APP_NAME=Alpha-Life Engine
VITE_APP_VERSION=1.0.0

# API 超时配置（毫秒）
VITE_API_TIMEOUT=30000

# React Query 配置
VITE_QUERY_STALE_TIME=300000
VITE_QUERY_CACHE_TIME=600000

# 市场数据配置
VITE_MARKET_DATA_UPDATE_INTERVAL=60000

# 触发线配置
VITE_TRIGGER_LINE=1667

# ETF 代码配置
VITE_SAFE_LAYER_PRIMARY=sh.511360
VITE_SAFE_LAYER_BACKUP=sh.511880

# 委佣配置
VITE_COMMISSION_RATE=0.0003
VITE_COMMISSION_MIN=5

# 策略进化配置
VITE_STRATEGY_EVOLUTION_WARNING_DAYS=45
VITE_STRATEGY_EVOLUTION_CRITICAL_DAYS=45
VITE_PBO_THRESHOLD=0.5
