{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node"], 
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src",
    "functions",
    "database",
    "scripts",
    "vite.config.ts",
    "worker-configuration.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}