{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "src",
    "scripts",
    "database",
    "functions",
    "types",
    "vite.config.ts",
    "\.github/workflows/*.yml"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
