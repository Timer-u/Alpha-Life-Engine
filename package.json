{
  "name": "alpha-life-engine",
  "version": "1.0.0",
  "description": "Alpha-Life Engine - Personal Quantitative DCA System",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "backend:dev": "wrangler dev --port 8787",
    "pages:deploy": "wrangler deploy",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --d1 DB=a491d7ba-045d-4303-a10b-ae25591e8164 --port 8787",
    "database:migrate": "wrangler d1 execute alpha-life-dev --file=./database/schema.sql --local --env development",
    "database:migrate:prod": "wrangler d1 execute alpha-life-prod --file=./database/schema.sql --remote --env production",
    "baoStock:setup": "tsx scripts/bao-stock-setup.ts",
    "baoStock:update": "tsx scripts/bao-stock-setup.ts",
    "market:init": "npm run baoStock:setup && npm run database:migrate",
    "market:init:prod": "npm run baoStock:setup && npm run database:migrate:prod",
    "market:update": "tsx scripts/daily-market-update.ts",
    "database:import-market": "wrangler d1 execute alpha-life-dev --file=./data/market_data/import_market_data.sql --local",
    "database:import-market:prod": "wrangler d1 execute alpha-life-prod --file=./data/market_data/import_market_data.sql --remote",
    "market:update:prod": "tsx scripts/daily-market-update.ts --prod",
    "types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:python": "ruff check scripts/local_evolver/ data/",
    "lint:python:fix": "ruff check --fix scripts/local_evolver/ data/",
    "format:python": "ruff format --check scripts/local_evolver/ data/",
    "format:python:fix": "ruff format scripts/local_evolver/ data/",
    "typecheck:python": "MYPYPATH=scripts/local_evolver mypy --strict --explicit-package-bases scripts/local_evolver/ data/",
    "security:python": "bandit -r scripts/local_evolver/ data/ -c pyproject.toml",
    "lint:python:all": "npm run lint:python && npm run format:python && npm run typecheck:python && npm run security:python",
    "evolve": "python scripts/local_evolver/evolver.py"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "date-fns": "^4.4.0",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "hono": "^4.12.28",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.1",
    "@cloudflare/workers-types": "^4.20260626.1",
    "@eslint-react/eslint-plugin": "^5.12.1",
    "@eslint/js": "^10.0.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "wrangler": "^4.100.0"
  },
  "allowScripts": {
    "esbuild@*": true,
    "sharp@*": true,
    "workerd@*": true
  }
}
