{
  "name": "alpha-life-engine",
  "version": "1.0.0",
  "description": "Alpha-Life Engine - Personal Quantitative DCA System",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "backend:dev": "wrangler dev --port 8787",
    "pages:deploy": "wrangler deploy",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --d1 DB=a491d7ba-045d-4303-a10b-ae25591e8164 --port 8787",
    "database:migrate": "wrangler d1 execute alpha-life-dev --file=./database/schema.sql --local --env development",
    "database:migrate:prod": "wrangler d1 execute alpha-life-prod --file=./database/schema.sql --remote --env production",
    "baoStock:setup": "tsx scripts/bao-stock-setup.ts",
    "baoStock:update": "tsx scripts/bao-stock-setup.ts",
    "market:init": "npm run baoStock:setup && npm run database:migrate",
    "market:init:prod": "npm run baoStock:setup && npm run database:migrate:prod",
    "market:update": "tsx scripts/daily-market-update.ts",
    "market:update:prod": "tsx scripts/daily-market-update.ts --prod",
    "types": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.74.0",
    "date-fns": "^4.4.0",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.6",
    "hono": "^4.12.26",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "wrangler": "^4.100.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true,
    "esbuild@0.27.3": true,
    "sharp@0.34.5": true,
    "workerd@1.20260617.1": true
  }
}
